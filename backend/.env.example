# ============================================================
# LocalTV Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.

# --- Persistent Data Directory ---
# Set this to a folder OUTSIDE the project directory so that
# your database (data.db) and uploaded media files (uploads/)
# survive code updates and deploys.
#
# Example for Windows:
# DATA_DIR=C:/localTV_data
#
# Example for Linux/macOS:
# DATA_DIR=/var/data/localtv
#
# Leave empty (or do not set) to use the default local path
# inside the backend/ folder (good for development only).
DATA_DIR=

# --- Admin Password ---
ADMIN_PASSWORD=admin123

#---Assistente ---
GEMINI_API_KEY=your-gemini-key-here
##OPENAI_API_KEY=your-key-here
GEMMA_MODEL=kimi-k2.5:cloud
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

